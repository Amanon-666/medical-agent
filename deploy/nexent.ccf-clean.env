# Nexent .env for CCF clean environment test
# Based on server v2.1.0 config, adapted for local WSL deployment

# ---- Image references ----
NEXENT_IMAGE=nexent/nexent:v2.1.0
NEXENT_WEB_IMAGE=nexent/nexent-web:v2.1.0
NEXENT_DATA_PROCESS_IMAGE=nexent/nexent-data-process:v2.1.0
ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.17.4
POSTGRESQL_IMAGE=postgres:15-alpine
REDIS_IMAGE=redis:alpine
MINIO_IMAGE=quay.io/minio/minio:RELEASE.2023-12-20T01-00-02Z
OPENSSH_SERVER_IMAGE=nexent/nexent-ubuntu-terminal:v2.1.0

# ---- Elasticsearch ----
ELASTIC_PASSWORD=nexent@2025
ES_JAVA_OPTS=-Xms1g -Xmx1g
ES_DISK_WATERMARK_LOW=85%
ES_DISK_WATERMARK_HIGH=90%
ES_DISK_WATERMARK_FLOOD_STAGE=95%

# ---- Postgres (Nexent own DB, NOT Supabase) ----
POSTGRES_HOST=nexent-postgresql
POSTGRES_PORT=5432
POSTGRES_USER=root
NEXENT_POSTGRES_PASSWORD=nexent@4321
POSTGRES_DB=nexent

# ---- MinIO ----
MINIO_ROOT_USER=nexent
MINIO_ROOT_PASSWORD=nexent@4321
MINIO_ACCESS_KEY=0823c1a70f379391282a9d58
MINIO_SECRET_KEY=LnCkrsSX5ItHXNxgAoF91B435OU5ZsI6LWWTeU+QdDA=
MINIO_REGION=cn-north-1
MINIO_DEFAULT_BUCKET=nexent

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Service URLs (internal, container-to-container) ----
ELASTICSEARCH_HOST=http://nexent-elasticsearch:9200
CONFIG_SERVICE_URL=http://nexent-config:5010
RUNTIME_SERVICE_URL=http://nexent-runtime:5014
NEXENT_MCP_SERVER=http://nexent-mcp:5011
DATA_PROCESS_SERVICE=http://nexent-data-process:5012/api
NORTHBOUND_API_SERVER=http://nexent-northbound:5013/api

# ---- JWT / Security ----
JWT_SECRET=ccf-test-jwt-secret-change-in-production
SECRET_KEY_BASE=ccf-test-secret-key-base-change-in-production
VAULT_ENC_KEY=ccf-test-vault-key-change-in-production

# ---- Proxy (no proxy in clean env) ----
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,nexent-elasticsearch,nexent-postgresql,nexent-minio,nexent-config,nexent-runtime,redis

# ---- Service flags ----
DOCKER_ENVIRONMENT=true
ENABLE_TELEMETRY=false
skip_proxy=true
UMASK=0022

# ---- Data processing ----
RAY_NUM_CPUS=2
RAY_OBJECT_STORE_MEMORY_GB=0.25

# ---- Market (disable external market) ----
MARKET_BACKEND=http://localhost:8010

# ---- Root dir for data storage ----
ROOT_DIR=/home/elmana/ccf-clean-env/nexent-data
NEXENT_USER_DIR=/home/elmana/ccf-clean-env/nexent-user-data
TERMINAL_MOUNT_DIR=/home/elmana/ccf-clean-env/nexent-terminal

# ---- OAuth (disabled for test) ----
OAUTH_CALLBACK_BASE_URL=http://localhost:30001
DEPLOYMENT_VERSION=full
USER_INFO_QUERY_SOURCE=pg
