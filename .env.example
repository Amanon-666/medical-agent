# 医学数据智能体工程环境变量模板
# 使用方式：复制为 .env.runtime，按目标环境填写。以 # 开头的行为注释。

# ============================================================
# 必填配置（部署前必须修改）
# ============================================================

# LLM API Key（OpenAI 兼容协议，用于实体识别、关系抽取、NL2SQL）
CCF_LLM_API_KEY=

# LLM 接口地址与模型（默认使用 DeepSeek，可替换为其他兼容接口）
CCF_LLM_BASE_URL=https://api.deepseek.com/v1/chat/completions
CCF_LLM_MODEL=deepseek-chat

# Nexent 管理员账号与密码
CCF_NEXENT_EMAIL=suadmin@nexent.com
CCF_NEXENT_PASSWORD=

# 公网域名与各服务入口（分别填写，互不依赖）
CCF_PUBLIC_DOMAIN=mashiro.xin
CCF_NEXENT_FRONTEND_URL=https://nexent.mashiro.xin/
CCF_DATAMATE_FRONTEND_URL=https://datamate.mashiro.xin/
CCF_TASK3_DEMO_URL=https://demo.mashiro.xin/
CCF_MCP_PUBLIC_URL=https://mcp.mashiro.xin/mcp

# ============================================================
# 平台连接（通常保持默认值，仅当端口或网络拓扑不同时修改）
# ============================================================

# Nexent 配置与运行时接口（MCP 注册与 Agent 对话）
CCF_NEXENT_CONFIG_BASE=http://127.0.0.1:5010
CCF_NEXENT_RUNTIME_BASE=http://127.0.0.1:5014

# MCP 服务注册地址（Nexent 内部访问 MCP 的地址）
CCF_MCP_URL=http://127.0.0.1:8900/mcp
CCF_MCP_SERVICE_NAME=medical-ai

# DataMate API 与网关
CCF_DATAMATE_BASE=http://127.0.0.1:18000
CCF_DATAMATE_GATEWAY=http://127.0.0.1:8080

# ============================================================
# 数据路径
# ============================================================

# DataMate 数据集文件目录（任务一注册数据集时写入此目录）
CCF_DATASET_VOLUME=/home/share/docker-data/volumes/datamate-dataset-volume/_data

# DataMate 算子运行目录
CCF_DATAMATE_OPERATOR_VOLUME=/home/share/docker-data/volumes/datamate-operator-runtime-volume/_data

# DataMate 算子运行容器名
CCF_DATAMATE_RUNTIME_CONTAINER=datamate-runtime

# 医学数据源目录（本地复现时可使用工程内演示数据）
CCF_DATA_ROOT=data/standard_diabetes_demo/datamate_upload

# 医学知识源数据（QASystemOnMedicalKG medical.json），离线构建 KG 时必需
CCF_MEDICAL_KG_DATA=

# 知识图谱库与分析库路径（Python 代码使用）
CCF_MEDICAL_KG_DB=data/task2_medical_kg.db
CCF_ANALYTICS_DB=data/task3_analytics.db

# 知识图谱库与分析库路径（部署脚本使用，与上两行指向同一文件）
CCF_TASK2_KG_DB=data/task2_medical_kg.db
CCF_TASK3_ANALYTICS_DB=data/task3_analytics.db

# sudo 密码（读取 DataMate 数据卷时需要，在线验证可不填）
CCF_SUDO_PW=

# ============================================================
# 可选配置
# ============================================================

# 从文件读取 LLM API Key（Docker secrets 场景）
CCF_LLM_API_KEY_FILE=/run/secrets/ccf_llm_api_key

# 向量嵌入模型（用于 Nexent 知识库搜索，不影响基础任务流程）
CCF_EMBED_API_KEY=
CCF_EMBED_BASE_URL=https://api.siliconflow.cn/v1/embeddings
CCF_EMBED_MODEL=BAAI/bge-large-zh-v1.5

# Agent ID（覆盖脚本默认值，通常无需修改）
CCF_TASK1_AGENT_ID=3
CCF_TASK2_AGENT_ID=4
CCF_TASK3_AGENT_ID=5

# 可视化平台数据来源删除令牌（填入任意非空值即启用删除功能）
CCF_DEMO_DELETE_TOKEN=
